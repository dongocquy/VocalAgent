# VocalAgent Configuration — Environment Variables
# Copy this to .env and fill in your actual values.
# If set, these take priority over values stored in the SQLite config DB.

# Active provider: "deepseek" or "openai" (default: deepseek)
# VOCALAGENT_PROVIDER=deepseek

# API keys — set at least one depending on your provider
# VOCALAGENT_DEEPSEEK_API_KEY=your_deepseek_api_key_here
# VOCALAGENT_OPENAI_API_KEY=your_openai_api_key_here

# Optional: override model
# VOCALAGENT_DEEPSEEK_MODEL=deepseek-v4-flash
# VOCALAGENT_OPENAI_MODEL=gpt-4o-mini
